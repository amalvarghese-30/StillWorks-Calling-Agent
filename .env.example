# =============================================================================
#  MANAS GROUP INDIA — AI VOICE AGENT CONFIGURATION
#  Copy this file to .env and fill in your credentials
# =============================================================================

# --- 1. LIVEKIT CLOUD CREDENTIALS ---
# Sign up at https://cloud.livekit.io/
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_api_key
LIVEKIT_API_SECRET=your_api_secret

# --- 2. SPEECH-TO-TEXT (STT) ---
# Sign up at https://console.deepgram.com/
DEEPGRAM_API_KEY=your_deepgram_key
DEEPGRAM_STT_MODEL=nova-2
DEEPGRAM_STT_LANGUAGE=en

# --- 3. LARGE LANGUAGE MODEL (LLM) ---
# Choose "groq" or "openai"
LLM_PROVIDER=groq
# For Groq: https://console.groq.com/
GROQ_API_KEY=your_groq_key
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_TEMPERATURE=0.7
# For OpenAI uncomment below:
# OPENAI_API_KEY=your_openai_key

# --- 4. TEXT-TO-SPEECH (TTS) ---
# Supported providers: openai, sarvam, cartesia, deepgram
# Malayalam/Hindi auto-use Sarvam; English uses selected provider
TTS_PROVIDER=sarvam
# Sarvam AI: https://www.sarvam.ai/
SARVAM_API_KEY=your_sarvam_key
SARVAM_TTS_MODEL=bulbul:v2
# OpenAI TTS (if using):
# OPENAI_TTS_MODEL=tts-1
# Cartesia (if using):
# CARTESIA_API_KEY=your_cartesia_key

# --- 5. OUTBOUND SIP TRUNK (VOBIZ) ---
# For making outbound calls

VOBIZ_SIP_TRUNK_ID=7c8499bf-e93f-4c75-bc59-d7165b35b790
OUTBOUND_TRUNK_ID=ST_xxxxxxxxxx  # Usually same as above
VOBIZ_SIP_DOMAIN=your-sip-domain.sip.vobiz.ai
VOBIZ_USERNAME=your_username
VOBIZ_PASSWORD=your_password
VOBIZ_OUTBOUND_NUMBER=+91XXXXXXXXXX

# --- 6. INBOUND SIP TRUNK ---
# Dedicated AI phone number (new number from Vobiz for AI calls only)
MANAS_AI_PHONE_NUMBER=+91XXXXXXXXXX
# Inbound trunk ID — created by running 'python setup_inbound_trunk.py'
INBOUND_TRUNK_ID=ST_xxxxxxxxxx

# --- 7. CALL TRANSFER ---
# Default number to transfer calls to (Manas Group human support)
DEFAULT_TRANSFER_NUMBER=+91XXXXXXXXXX
MANAS_SUPPORT_NUMBER_1=+91XXXXXXXXXX
MANAS_SUPPORT_NUMBER_2=+91XXXXXXXXXX

# --- 8. MANAS GROUP BUSINESS INFO ---
MANAS_EMAIL=mail@manasgroupindia.in
MANAS_ADDRESS=Vellapara, Chithali post, Palakkad Dist., Kerala
WEBSITE=www.manasgroupindia.in

# --- 9. DATABASE ---
DATABASE_PATH=data/manas_group.db

# --- 10. OUTBOUND CALL LIMITS ---
MAX_OUTBOUND_CALLS_PER_HOUR=50
OUTBOUND_CALL_WINDOW_START=09:00
OUTBOUND_CALL_WINDOW_END=18:00

# --- 11. LANGUAGE DEFAULTS ---
DEFAULT_OUTBOUND_LANGUAGE=ml
# Supported: ml (Malayalam), en (English), hi (Hindi)
